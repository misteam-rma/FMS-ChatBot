# ── Frontend (Vite) environment ───────────────────────────
# Copy to .env.local for local dev, or set in the Vercel dashboard for prod.

# Base URL of the backend API (the Render service), INCLUDING the /api suffix.
# Production example:
#   VITE_API_BASE_URL=https://finance-chatbot-9ni2.onrender.com/api
#
# Leave UNSET for local dev — the app then auto-detects:
#   - Vite dev server (port 5173) -> talks to FastAPI on http://localhost:8000/api
#   - same-origin otherwise
VITE_API_BASE_URL=
