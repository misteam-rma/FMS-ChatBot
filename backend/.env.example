# ── Backend (FastAPI) environment ─────────────────────────
# Copy to backend/.env for local dev, or set these in the Render dashboard.
# Config is read by app/config.py from backend/.env or the repo-root .env.

# Database
DATABASE_URL=sqlite+aiosqlite:///./botivate_master.db

# JWT & App Security
# In any non-"development" APP_ENV the app REFUSES to start if these are left
# at their default values (see Settings.validate_production_secrets).
JWT_SECRET_KEY=change-this-to-a-random-32-character-string
APP_SECRET_KEY=change-this-to-a-strong-random-secret

# Environment: "development" (relaxed checks) or "production" (strict).
APP_ENV=development

# CORS — comma-separated allowed origins. The frontend is on Vercel, so in
# production this MUST list the Vercel domain(s) for the browser to make
# credentialed cross-origin calls. Leave "*" only in local dev (note: "*"
# disables credentialed CORS — browsers forbid "*" + credentials).
#   ALLOWED_ORIGINS=https://your-app.vercel.app,https://rma.yourdomain.com
ALLOWED_ORIGINS=*

# OpenAI LLM
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Fast LLM (Optional — used for data answers / policy queries; falls back to
# OPENAI_MODEL when unset). Cerebras: https://api.cerebras.ai/v1
# Groq: https://api.groq.com/openai/v1
FAST_LLM_API_KEY=
FAST_LLM_MODEL=
FAST_LLM_BASE_URL=

# Application
APP_NAME=Finance FMS Portal

# Google Sheets
# GOOGLE_SHEET_ID is the {SHEET_ID} in the workbook URL.
GOOGLE_SHEET_ID=1E6HKeoYxOrroF-ogNpmyks-nuYX4f-iUjFMG7Fu2X_4
GOOGLE_EMPLOYEE_SHEET_NAME=RAW DATA
GOOGLE_ADMIN_SHEET_NAME=Admin

# Service account JSON (paste the entire JSON as a single line).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}

# Disable Google auth for testing (false for production).
SKIP_GOOGLE_AUTH=false
